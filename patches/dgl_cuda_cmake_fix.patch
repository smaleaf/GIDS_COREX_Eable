--- a/cmake/modules/CUDA.cmake
+++ b/cmake/modules/CUDA.cmake
@@ -223,11 +223,14 @@ macro(dgl_config_cuda out_variable)
   # 0. Add host flags
   message(STATUS "CMAKE_CXX_FLAGS: ${CMAKE_CXX_FLAGS}")
-  string(REGEX REPLACE "[ \t\n\r]" "," CXX_HOST_FLAGS "${CMAKE_CXX_FLAGS}")
+  string(STRIP "${CMAKE_CXX_FLAGS}" CXX_HOST_FLAGS_STRIPPED)
+  string(REGEX REPLACE "[ \t\n\r]+" ";" CXX_HOST_FLAGS_LIST "${CXX_HOST_FLAGS_STRIPPED}")
   if(MSVC AND NOT USE_MSVC_MT)
-    string(CONCAT CXX_HOST_FLAGS ${CXX_HOST_FLAGS} ",/MD")
+    list(APPEND CXX_HOST_FLAGS_LIST "/MD")
   endif()
-  list(APPEND CUDA_NVCC_FLAGS "-Xcompiler" "${CXX_HOST_FLAGS}")
+  foreach(flag ${CXX_HOST_FLAGS_LIST})
+    list(APPEND CUDA_NVCC_FLAGS "-Xcompiler" "${flag}")
+  endforeach()
+  # Corex: clang++ doesn't bundle omp.h; add GCC's OpenMP include path
+  list(APPEND CUDA_NVCC_FLAGS "-Xcompiler" "-I/usr/lib/gcc/x86_64-linux-gnu/11/include")
 
   # 1. Add arch flags
   dgl_select_nvcc_arch_flags(NVCC_FLAGS_ARCH)